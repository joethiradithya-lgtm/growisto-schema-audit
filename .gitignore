*.py[cod]
*.pyo
*.pyd
.Python
*.so
.venv/
venv/
env/
ENV/

# Plugin outputs — generated files go into Outputs/ (folder tracked via .gitkeep,
# contents gitignored so generated XLSX/CSV/JSON files never get committed).
Outputs/*
!Outputs/.gitkeep

# Legacy: any output folder elsewhere + XLSX/results.json anywhere else
output/
*.xlsx
results.json
schema-audit-*.json
!scripts/schema_audit/results.json.example

