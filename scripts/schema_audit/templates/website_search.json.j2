{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "{{ scraped.organization_name or 'REPLACE_ME_SITE_NAME' }}",
  "url": "{{ scraped.url }}",
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "{{ scraped.url.rstrip('/') }}/search?q={search_term_string}"
    },
    "query-input": "required name=search_term_string"
  }
}
