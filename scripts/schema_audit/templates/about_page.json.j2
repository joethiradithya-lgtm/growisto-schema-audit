{
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "url": "{{ scraped.url }}",
  "name": "{{ scraped.title or 'About REPLACE_ME_ORG_NAME' }}",
  "description": "{{ scraped.description or 'REPLACE_ME_DESCRIPTION' }}",
  "mainEntity": {
    "@type": "Organization",
    "name": "{{ scraped.organization_name or 'REPLACE_ME_ORG' }}",
    "url": "{{ scraped.url.split('://')[0] }}://{{ scraped.url.split('://')[1].split('/')[0] }}/",
    "logo": "{{ scraped.logo_url or 'REPLACE_ME_LOGO' }}"
  }
}
